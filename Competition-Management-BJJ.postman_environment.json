{
  "id": "competition-management-bjj-env",
  "name": "Competition Management BJJ - Local",
  "values": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:3000",
      "description": "Base URL for the local Express API pointing to remote Firebase",
      "enabled": true
    },
    {
      "key": "api_key",
      "value": "your-api-key-here",
      "description": "API key for authentication - set this to match your API_KEY_FILE content",
      "enabled": true
    },
    {
      "key": "tenant_id",
      "value": "your-tenant-id",
      "description": "Tenant ID for multi-tenancy",
      "enabled": true
    },
    {
      "key": "firebase_token",
      "value": "your-firebase-id-token-here",
      "description": "Firebase ID token obtained from login or authentication",
      "enabled": true
    },
    {
      "key": "user_id",
      "value": "user-id-here",
      "description": "User ID for operations that require a specific user",
      "enabled": true
    },
    {
      "key": "approval_id",
      "value": "approval-id-here",
      "description": "Approval ID for approval operations",
      "enabled": true
    },
    {
      "key": "birth_date",
      "value": "2000-01-01",
      "description": "Birth date for graduation calculations (format: YYYY-MM-DD)",
      "enabled": true
    }
  ],
  "_postman_variable_scope": "environment"
}