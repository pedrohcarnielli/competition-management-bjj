# Servidor local (não incluir PORT, é reservado no Firebase Functions)
LOCAL_PORT=3000

# Seguranca
API_KEY_FILE=api-key-secret.txt
GCP_TENANT_ID=your-tenant-id

# Firebase Web Auth (prefixo FB_ para evitar conflito com variáveis reservadas)
FB_WEB_API_KEY=your-firebase-web-api-key
FB_PROJECT_ID=competition-management-bjj
FB_AUTH_DOMAIN=competition-management-bjj.firebaseapp.com

# Firebase Admin (GOOGLE_APPLICATION_CREDENTIALS é permitido)
GOOGLE_APPLICATION_CREDENTIALS=firebase-config/competition-management-bjj-firebase.json
FB_STORAGE_BUCKET=gs://competition-management-bjj.firebasestorage.app

# Email (Nodemailer) - opcional, usado quando a extensão Firebase não está instalada
# EMAIL_USER=seu.email@gmail.com
# EMAIL_PASSWORD=sua-senha-de-app-ou-token
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_FROM=noreply@bjj-competition.com

# Firestore
MAIL_COLLECTION=mail
