{
  "info": {
    "name": "Competition Management BJJ API",
    "description": "API for managing BJJ competition users, approvals, and graduations using Firebase Functions",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login"
              ]
            },
            "description": "Authenticate user and get Firebase token. Copy the token from response to firebase_token environment variable."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/getUsers",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "getUsers"
              ]
            },
            "description": "Get list of all active users"
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/getUserById?id={{user_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "getUserById"
              ],
              "query": [
                {
                  "key": "id",
                  "value": "{{user_id}}"
                }
              ]
            },
            "description": "Get specific user by ID"
          }
        },
        {
          "name": "Get User History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/getUserHistory?id={{user_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "getUserHistory"
              ],
              "query": [
                {
                  "key": "id",
                  "value": "{{user_id}}"
                }
              ]
            },
            "description": "Get history of changes for a specific user"
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"João Silva\",\n  \"birthDate\": \"1990-01-01\",\n  \"weight\": 75.5,\n  \"graduation\": \"branca\",\n  \"email\": \"joao.silva@example.com\",\n  \"phone\": \"+5511999999999\",\n  \"documentNumber\": \"123.456.789-00\",\n  \"roles\": [\"atleta\"],\n  \"responsibleLegalEmail\": \"legal@example.com\",\n  \"technicalResponsibleEmail\": \"technical@example.com\",\n  \"password\": \"password123\",\n  \"photoBase64\": \"base64-encoded-image-here\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/createUserFunction",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "createUserFunction"
              ]
            },
            "description": "Create a new user. photoBase64 is optional."
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"João Silva Atualizado\",\n  \"birthDate\": \"1990-01-01\",\n  \"weight\": 76.0,\n  \"graduation\": \"azul\",\n  \"email\": \"joao.silva@example.com\",\n  \"phone\": \"+5511999999999\",\n  \"documentNumber\": \"123.456.789-00\",\n  \"roles\": [\"atleta\"],\n  \"responsibleLegalEmail\": \"legal@example.com\",\n  \"technicalResponsibleEmail\": \"technical@example.com\",\n  \"photoBase64\": \"base64-encoded-image-here\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/updateUserFunction?id={{user_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "updateUserFunction"
              ],
              "query": [
                {
                  "key": "id",
                  "value": "{{user_id}}"
                }
              ]
            },
            "description": "Update an existing user. Set user_id in environment variables."
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/deleteUserFunction?id={{user_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "deleteUserFunction"
              ],
              "query": [
                {
                  "key": "id",
                  "value": "{{user_id}}"
                }
              ]
            },
            "description": "Soft delete a user. Set user_id in environment variables."
          }
        }
      ]
    },
    {
      "name": "Approvals",
      "item": [
        {
          "name": "Get Approvals",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/getApprovalsFunction",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "getApprovalsFunction"
              ]
            },
            "description": "Get list of pending approvals"
          }
        },
        {
          "name": "Respond to Approval",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"approverEmail\": \"approver@example.com\",\n  \"approve\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/respondApprovalFunction?id={{approval_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "respondApprovalFunction"
              ],
              "query": [
                {
                  "key": "id",
                  "value": "{{approval_id}}"
                }
              ]
            },
            "description": "Approve or reject an approval request. Set approval_id in environment variables."
          }
        }
      ]
    },
    {
      "name": "Graduations",
      "item": [
        {
          "name": "Get Graduations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/getGraduations?birthDate={{birth_date}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "getGraduations"
              ],
              "query": [
                {
                  "key": "birthDate",
                  "value": "{{birth_date}}"
                }
              ]
            },
            "description": "Get list of available BJJ graduations based on birth date. Set birth_date in environment variables (format: YYYY-MM-DD)."
          }
        }
      ]
    },
    {
      "name": "Roles",
      "item": [
        {
          "name": "Get Roles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/getRoles",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "getRoles"
              ]
            },
            "description": "Get list of available roles."
          }
        },
        {
          "name": "Get Users by Role",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/getUsersByRole?role={{role}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "getUsersByRole"
              ],
              "query": [
                {
                  "key": "role",
                  "value": "{{role}}",
                  "description": "Optional role filter (e.g., Aluno, responsável legal, etc.)"
                }
              ]
            },
            "description": "Get users filtered by role. Leave role parameter empty to get all users."
          }
        }
      ]
    },
