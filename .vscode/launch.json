{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Run Local API (Production)",
            "runtimeExecutable": "node",
            "program": "${workspaceFolder}/node_modules/ts-node/dist/bin.js",
            "args": [
                "src/index.ts"
            ],
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**",
                "node_modules/**"
            ]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Local API",
            "runtimeExecutable": "node",
            "program": "${workspaceFolder}/node_modules/ts-node/dist/bin.js",
            "args": [
                "--transpile-only",
                "src/index.ts"
            ],
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**",
                "node_modules/**"
            ]
        }
    ]
}