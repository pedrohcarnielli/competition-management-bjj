{
  "name": "competition-management-bjj-api",
  "version": "0.1.0",
  "description": "Firebase Functions API para gerenciamento de usuários BJJ",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "node -r ts-node/register src/index.ts",
    "serve:debug": "node --inspect-brk -r ts-node/register src/index.ts",
    "local": "node -r ts-node/register src/index.ts",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "firebase": "^12.12.0",
    "firebase-admin": "^11.0.0",
    "firebase-functions": "^4.3.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.2",
    "express": "^5.2.1",
    "firebase-functions-test": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "private": true
}
